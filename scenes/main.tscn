;; ═══ UI Layer ═══
[node name="UI" type="CanvasLayer" parent="."]

[node name="InteractionPrompt" type="Label" parent="UI"]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -200.0
offset_top = -120.0
offset_right = 200.0
offset_bottom = -80.0
text = "Press E to interact"
horizontal_alignment = 1
vertical_alignment = 1
script = ExtResource("4")

[node name="ConnectionStatus" type="Label" parent="UI"]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -200.0
offset_top = 10.0
offset_right = -10.0
offset_bottom = 30.0
horizontal_alignment = 2
script = ExtResource("5")

[node name="DialoguePanel" type="PanelContainer" parent="UI" groups=["dialogue_panel"]]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -420.0
offset_top = -320.0
offset_right = 420.0
offset_bottom = -20.0
script = ExtResource("3")

[node name="MarginContainer" type="MarginContainer" parent="UI/DialoguePanel"]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="UI/DialoguePanel/MarginContainer"]
layout_mode = 2

[node name="Header" type="HBoxContainer" parent="UI/DialoguePanel/MarginContainer/VBox"]
layout_mode = 2

[node name="Portrait" type="ColorRect" parent="UI/DialoguePanel/MarginContainer/VBox/Header"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(56, 56)
color = Color(0.85, 0.65, 0.13, 1)

[node name="NameBox" type="VBoxContainer" parent="UI/DialoguePanel/MarginContainer/VBox/Header"]
layout_mode = 2

[node name="NPCName" type="Label" parent="UI/DialoguePanel/MarginContainer/VBox/Header/NameBox"]
unique_name_in_owner = true
layout_mode = 2
text = "NPC Name"
theme_override_font_sizes/font_size = 18

[node name="NPCRole" type="Label" parent="UI/DialoguePanel/MarginContainer/VBox/Header/NameBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Role"
theme_override_font_sizes/font_size = 13
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)

[node name="Spacer" type="Control" parent="UI/DialoguePanel/MarginContainer/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3

[node name="EmotionBox" type="HBoxContainer" parent="UI/DialoguePanel/MarginContainer/VBox/Header"]
layout_mode = 2

[node name="EmotionColor" type="ColorRect" parent="UI/DialoguePanel/MarginContainer/VBox/Header/EmotionBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(20, 20)
color = Color(0.6, 0.6, 0.6, 1)

[node name="EmotionLabel" type="Label" parent="UI/DialoguePanel/MarginContainer/VBox/Header/EmotionBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Neutral"
theme_override_font_sizes/font_size = 13

[node name="MoodBar" type="ProgressBar" parent="UI/DialoguePanel/MarginContainer/VBox/Header/EmotionBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(60, 0)
value = 50.0
show_percentage = false

[node name="HSeparator" type="HSeparator" parent="UI/DialoguePanel/MarginContainer/VBox"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="UI/DialoguePanel/MarginContainer/VBox"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(0, 140)

[node name="DialogueText" type="RichTextLabel" parent="UI/DialoguePanel/MarginContainer/VBox/ScrollContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
scroll_following = true

[node name="InputRow" type="HBoxContainer" parent="UI/DialoguePanel/MarginContainer/VBox"]
layout_mode = 2

[node name="PlayerInput" type="LineEdit" parent="UI/DialoguePanel/MarginContainer/VBox/InputRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Say something..."

[node name="SendBtn" type="Button" parent="UI/DialoguePanel/MarginContainer/VBox/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Send"

[node name="TradeBtn" type="Button" parent="UI/DialoguePanel/MarginContainer/VBox/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Trade"
visible = false

[node name="QuestBtn" type="Button" parent="UI/DialoguePanel/MarginContainer/VBox/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Accept Quest"
visible = false

[node name="CloseBtn" type="Button" parent="UI/DialoguePanel/MarginContainer/VBox/InputRow"]
unique_name_in_owner = true
layout_mode = 2
text = "X"

;; ═══ Area3D Signal Connections ═══
[connection signal="body_entered" from="MerchantElara/InteractionZone" to="MerchantElara" method="_on_interaction_zone_body_entered"]
[connection signal="body_exited" from="MerchantElara/InteractionZone" to="MerchantElara" method="_on_interaction_zone_body_exited"]
[connection signal="body_entered" from="GuardTheron/InteractionZone" to="GuardTheron" method="_on_interaction_zone_body_entered"]
[connection signal="body_exited" from="GuardTheron/InteractionZone" to="GuardTheron" method="_on_interaction_zone_body_exited"]
[connection signal="body_entered" from="QuestGiverMiriam/InteractionZone" to="QuestGiverMiriam" method="_on_interaction_zone_body_entered"]
[connection signal="body_exited" from="QuestGiverMiriam/InteractionZone" to="QuestGiverMiriam" method="_on_interaction_zone_body_exited"]
