[gd_scene load_steps=18 format=3 uid="uid://main_scene"]

[ext_resource type="Script" path="res://scripts/player/player_controller.gd" id="1"]
[ext_resource type="Script" path="res://scripts/npc/npc_character.gd" id="2"]
[ext_resource type="Script" path="res://scripts/ui/dialogue_panel.gd" id="3"]
[ext_resource type="Script" path="res://scripts/ui/interaction_prompt.gd" id="4"]
[ext_resource type="Script" path="res://scripts/ui/connection_status.gd" id="5"]

[sub_resource type="ProceduralSkyMaterial" id="sky_mat"]
sky_top_color = Color(0.35, 0.55, 0.82, 1)
sky_horizon_color = Color(0.65, 0.75, 0.85, 1)
ground_bottom_color = Color(0.2, 0.17, 0.13, 1)
ground_horizon_color = Color(0.65, 0.75, 0.85, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 2
ambient_light_color = Color(0.75, 0.7, 0.65, 1)
ambient_light_energy = 0.3
tonemap_mode = 2

[sub_resource type="CapsuleShape3D" id="player_shape"]
radius = 0.35
height = 1.8

[sub_resource type="CapsuleMesh" id="player_mesh"]
radius = 0.35
height = 1.8

[sub_resource type="CapsuleShape3D" id="npc_shape"]
radius = 0.4
height = 1.8

[sub_resource type="CapsuleMesh" id="npc_mesh"]
radius = 0.4
height = 1.8

[sub_resource type="SphereMesh" id="orb_mesh"]
radius = 0.15
height = 0.3

[sub_resource type="SphereShape3D" id="interact_sphere"]
radius = 5.0

[sub_resource type="BoxShape3D" id="ground_shape"]
size = Vector3(40, 0.2, 40)

[sub_resource type="BoxMesh" id="ground_mesh"]
size = Vector3(40, 0.2, 40)

[sub_resource type="StandardMaterial3D" id="ground_mat"]
albedo_color = Color(0.35, 0.28, 0.18, 1)

[node name="DemoVillage" type="Node3D"]

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("env")

[node name="DirectionalLight" type="DirectionalLight3D" parent="."]
